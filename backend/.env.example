# Copy this file to backend/.env. Never commit backend/.env.
ENVIRONMENT=development

# Neon Dashboard -> Connect. Paste the generated URLs exactly so credentials
# remain correctly URL-encoded. DATABASE_URL uses the `-pooler` hostname for
# application traffic; DATABASE_URL_DIRECT uses the direct hostname for schema setup.
DATABASE_URL=postgresql://YOUR_NEON_ROLE:YOUR_NEON_PASSWORD@ep-YOUR-ENDPOINT-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DIRECT=postgresql://YOUR_NEON_ROLE:YOUR_NEON_PASSWORD@ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# Supabase Dashboard -> Project Settings -> API. SUPABASE_URL derives both the
# issuer and the asymmetric signing-key endpoint used for ES256/RS256 tokens.
# Keep authentication enabled for every shared or production environment.
AUTH_REQUIRED=true
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_TTL_SECONDS=600
SUPABASE_JWKS_TIMEOUT_SECONDS=5

# Optional overrides for self-hosted/custom Supabase Auth deployments:
# SUPABASE_JWKS_URL=https://YOUR_AUTH_HOST/auth/v1/.well-known/jwks.json
# SUPABASE_JWT_ISSUER=https://YOUR_AUTH_HOST/auth/v1

# Legacy HS256 fallback only. New asymmetric projects do not need this secret.
SUPABASE_JWT_SECRET=
SUPABASE_JWT_ALGORITHM=HS256

# For an intentional local demo without Supabase, set AUTH_REQUIRED=false and
# leave SUPABASE_URL and SUPABASE_JWT_SECRET empty. Never use that configuration
# in production.

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=50
MAX_BATCH_SIZE_MB=100
MAX_ARCHIVE_UNCOMPRESSED_MB=100
MAX_ARCHIVE_ENTRIES=100
MAX_ARCHIVE_COMPRESSION_RATIO=100
MAX_IMAGE_PIXELS=50000000
MAX_PDF_PAGES=50
PDF_INFO_TIMEOUT_SECONDS=15
PDF_CONVERSION_TIMEOUT_SECONDS=120
PDF_DPI=200

# Startup maintenance removes abandoned temporary/unreferenced scan files only
# after this grace window, and bounds retry-response storage in Neon.
STORAGE_CLEANUP_GRACE_HOURS=24
IDEMPOTENCY_RETENTION_HOURS=168

# Comma-separated browser origins. Add the real deployed frontend URL in production.
CORS_ORIGINS=http://localhost:3000

# Host headers accepted by the API. Replace these with your API hostname in production.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
