# ======================================================================
# Markwise backend configuration
# ----------------------------------------------------------------------
# Copy this file to backend/.env and fill in the REQUIRED values.
#   cp .env.example .env            (macOS/Linux)
#   Copy-Item .env.example .env     (Windows PowerShell)
# backend/.env holds secrets and is git-ignored. Never commit it.
#
# Legend:  [REQUIRED] must be set   [optional] safe to leave as-is
# ======================================================================


# ----------------------------------------------------------------------
# 1. Environment
# ----------------------------------------------------------------------
# "development" (local) or "production". In production the app refuses to
# start unless auth is enabled, the JWT secret is strong, and CORS/hosts
# use HTTPS (see sections 3 and 6 below).
ENVIRONMENT=development


# ----------------------------------------------------------------------
# 2. Database (Neon PostgreSQL)   [REQUIRED]
# ----------------------------------------------------------------------
# Neon Dashboard -> Connect. Copy the URLs exactly so the password stays
# correctly URL-encoded.
#   DATABASE_URL        -> the POOLED url (host contains "-pooler"). Used
#                          for all normal app traffic.
#   DATABASE_URL_DIRECT -> the DIRECT url (no "-pooler"). Used only to run
#                          schema migrations. If omitted, DATABASE_URL is
#                          reused.
DATABASE_URL=postgresql://YOUR_NEON_ROLE:YOUR_NEON_PASSWORD@ep-YOUR-ENDPOINT-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require
DATABASE_URL_DIRECT=postgresql://YOUR_NEON_ROLE:YOUR_NEON_PASSWORD@ep-YOUR-ENDPOINT.us-east-2.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Connection pool sizing. Total connections used = (pool + overflow) per
# process; keep within your Neon plan limit.   [optional]
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5


# ----------------------------------------------------------------------
# 3. Authentication   [REQUIRED for any shared/production deploy]
# ----------------------------------------------------------------------
# Accounts sign in with email + password. The API issues a short-lived
# access token (JWT) plus a rotating refresh token, all stored in Neon.

# Set to false ONLY for a throwaway local demo with no login. Must be
# true in production.
AUTH_REQUIRED=true

# Secret that signs access tokens. REQUIRED when AUTH_REQUIRED=true.
# Generate a strong random value (>= 32 chars required in production):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# Changing it logs everyone out (all existing access tokens stop working).
AUTH_JWT_SECRET=

# Token lifetimes.   [optional]
#   AUTH_JWT_ALGORITHM         -> only HS256 is supported.
#   AUTH_ACCESS_TOKEN_TTL_MINUTES -> 1..1440 (24h max).
#   AUTH_REFRESH_TOKEN_TTL_DAYS   -> 1..365.
AUTH_JWT_ALGORITHM=HS256
AUTH_ACCESS_TOKEN_TTL_MINUTES=30
AUTH_REFRESH_TOKEN_TTL_DAYS=30


# ----------------------------------------------------------------------
# 4. Admin console   [REQUIRED in production]
# ----------------------------------------------------------------------
# There is exactly ONE admin, and it is NOT a database account. The admin
# signs in at the frontend /admin page with only this shared password
# (no email, no user record). From there the admin creates and enables or
# disables teacher accounts. Teachers sign in normally on the main site.
#
# ADMIN_PASSWORD -> min 12 chars. Leave blank to disable the admin console
#                   entirely (e.g. a pure local demo). REQUIRED in
#                   production. Changing it invalidates any active admin
#                   session. Keep it strong and secret; the /admin URL is
#                   not a secret, the password is the only gate.
ADMIN_PASSWORD=


# ----------------------------------------------------------------------
# 5. Uploads and processing limits   [optional]
# ----------------------------------------------------------------------
# Where scan files are written. Relative paths are resolved from backend/.
UPLOAD_DIR=./uploads

# Per-file and per-batch size caps (MB). MAX_BATCH_SIZE_MB must be >=
# MAX_FILE_SIZE_MB. Keep these aligned with the NEXT_PUBLIC_* values in
# frontend/.env.local (the backend is authoritative either way).
MAX_FILE_SIZE_MB=10
MAX_FILES_PER_REQUEST=50
MAX_BATCH_SIZE_MB=100

# ZIP archive safety limits (guard against zip bombs / oversized uploads).
MAX_ARCHIVE_UNCOMPRESSED_MB=100
MAX_ARCHIVE_ENTRIES=100
MAX_ARCHIVE_COMPRESSION_RATIO=100

# Image / PDF processing limits. MAX_PDF_PAGES must be <=
# MAX_FILES_PER_REQUEST. DPI affects PDF render quality vs. speed.
MAX_IMAGE_PIXELS=50000000
MAX_PDF_PAGES=50
PDF_INFO_TIMEOUT_SECONDS=15
PDF_CONVERSION_TIMEOUT_SECONDS=120
PDF_DPI=200

# Startup maintenance: how long abandoned temp/unreferenced scan files are
# kept, and how long idempotent retry responses are retained.
STORAGE_CLEANUP_GRACE_HOURS=24
IDEMPOTENCY_RETENTION_HOURS=168


# ----------------------------------------------------------------------
# 6. Network / CORS   [REQUIRED to match your frontend]
# ----------------------------------------------------------------------
# Comma-separated browser origins allowed to call the API (no trailing
# slash). In production every origin must be https://. Set this to your
# real frontend URL when you deploy.
CORS_ORIGINS=http://localhost:3000

# Comma-separated Host headers the API will accept. In production set this
# to your API hostname(s); wildcards are rejected.
TRUSTED_HOSTS=localhost,127.0.0.1,testserver
