# ======================================================================
# Markwise frontend configuration
# ----------------------------------------------------------------------
# Copy this file to frontend/.env.local and adjust as needed.
#   cp .env.example .env.local            (macOS/Linux)
#   Copy-Item .env.example .env.local     (Windows PowerShell)
#
# Every variable here is prefixed NEXT_PUBLIC_ and is baked into the
# browser bundle at build time -> treat all values as PUBLIC. Never put a
# secret (database URL, JWT secret, API key) in this file.
#
# Authentication is handled entirely by the backend (email/password).
# No third-party auth keys are needed in the browser.
# ======================================================================


# ----------------------------------------------------------------------
# 1. Backend API   [REQUIRED]
# ----------------------------------------------------------------------
# Public origin of the FastAPI backend. No trailing slash. This origin
# must be listed in the backend's CORS_ORIGINS.
#   Local:      http://localhost:8000
#   Production: https://api.your-domain.com
NEXT_PUBLIC_API_URL=http://localhost:8000


# ----------------------------------------------------------------------
# 2. Upload limits (UI hints)   [optional]
# ----------------------------------------------------------------------
# Client-side hints so the UI can reject oversized uploads early. Keep
# these equal to the matching values in backend/.env; the backend
# re-validates every upload and remains authoritative.
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
NEXT_PUBLIC_MAX_FILES_PER_REQUEST=50
NEXT_PUBLIC_MAX_BATCH_SIZE_MB=100


# ----------------------------------------------------------------------
# 3. Local demo mode   [optional, local only]
# ----------------------------------------------------------------------
# When "true", the sign-in screen shows a "Continue in local demo" button
# that unlocks the UI without credentials. It only works against a backend
# started with AUTH_REQUIRED=false. Leave "false" for any shared or
# production deployment.
NEXT_PUBLIC_ALLOW_DEMO=false
