# Copy this file to frontend/.env.local.

# Public FastAPI origin. Do not include a trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Keep these browser-side limits aligned with backend/.env. The backend remains
# authoritative and also validates file contents after upload.
NEXT_PUBLIC_MAX_FILE_SIZE_MB=10
NEXT_PUBLIC_MAX_FILES_PER_REQUEST=50
NEXT_PUBLIC_MAX_BATCH_SIZE_MB=100

# Browser-safe values from Supabase Dashboard -> Project Settings -> API Keys.
# Use the publishable key (it starts with sb_publishable_). Replace both
# placeholders to enable sign-in. Leaving them unchanged keeps the UI in demo
# mode and requires backend AUTH_REQUIRED=false. Never put an sb_secret_ or
# service_role key in a NEXT_PUBLIC_* variable.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_key

# Legacy projects may uncomment this and use it instead. The placeholder above
# is ignored when a real legacy anon key is supplied:
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_legacy_anon_key
